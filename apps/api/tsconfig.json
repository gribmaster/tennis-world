{
  "extends": "@tennis/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": false,
    "isolatedModules": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
